# Получить диалог для NPC
static func get_dialogue(npc_type: String) -> Dictionary:
	if NPC_DIALOGUES.has(npc_type):
		return NPC_DIALOGUES[npc_type]
	return NPC_DIALOGUES["survivor"]

# Получить случайную тему для разговора
static func get_random_topic(npc_type: String) -> String:
	var dialogue = get_dialogue(npc_type)
	if dialogue.has("topics") and dialogue["topics"].size() > 0:
		return dialogue["topics"][randi() % dialogue["topics"].size()]
	return "..."

# Получить случайный ответ
static func get_random_response(npc_type: String) -> String:
	var dialogue = get_dialogue(npc_type)
	if dialogue.has("responses") and dialogue["responses"].size() > 0:
		return dialogue["responses"][randi() % dialogue["responses"].size()]
	return "..."

# Получить все типы NPC
static func get_all_npc_types() -> Array:
	return NPC_DIALOGUES.keys()
